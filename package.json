{
	"name": "m4l-strudel",
	"private": true,
	"version": "0.2.1",
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"description": "Max for Live MIDI device - Strudel mini-notation ↔ MIDI clip, rendered as a React app inside jweb",
	"scripts": {
		"dev": "vite --host 127.0.0.1 --port 5175",
		"build": "tsc -b && vite build && node scripts/build-node-bundles.mjs && node scripts/generate-patchers.mjs && node scripts/postbuild.mjs",
		"build:node": "node scripts/build-node-bundles.mjs",
		"build:patchers": "node scripts/generate-patchers.mjs",
		"preview": "vite preview --host 127.0.0.1 --port 4175",
		"test": "vitest run",
		"format": "prettier --write \"src/**/*.{ts,tsx,css}\""
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.460.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwind-merge": "^2.5.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.0.0",
		"@types/archiver": "^6.0.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"archiver": "^7.0.1",
		"esbuild": "^0.24.0",
		"prettier": "^3.4.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vite-plugin-singlefile": "^2.1.0",
		"vitest": "^2.1.0"
	}
}
